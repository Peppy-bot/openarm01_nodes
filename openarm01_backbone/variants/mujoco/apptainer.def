# TODO: replace with tuatini/peppy-python-uv-base:latest once published
Bootstrap: docker
From: python:3.11-slim

%labels
    Name openarm01-backbone-mujoco
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/peppy_python:/opt/mujoco_backbone/exts/mujoco.peppy.backbone:/opt/nodes_shared_code:/opt/mujoco_backbone/.peppy/libs:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-0}
    export PEPPY_BRIDGE_NODE_NAME=sim

# All assets (exts, robots, config, peppy.json5) are bind-mounted
# at runtime via mount_paths in peppy.json5 — nothing to copy at build time.
%files

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true update \
    && apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true install -y --no-install-recommends \
        libgl1 \
        libgl1-mesa-dri \
        libglib2.0-0 \
        libgomp1 \
        libosmesa6 \
        ca-certificates
    rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir \
        mujoco \
        numpy

%runscript
    cd /opt/mujoco_backbone
    _PRESET="${PEPPY_BRIDGE_PRESET:-mujoco_openarm}"
    _CONFIG="/opt/mujoco_backbone/config/presets/${_PRESET}.json5"
    if [ ! -f "${_CONFIG}" ]; then
        echo "ERROR: mujoco backbone preset not found: ${_CONFIG}" >&2
        echo "       Set PEPPY_BRIDGE_PRESET to a valid preset name." >&2
        exit 1
    fi
    export PEPPY_BRIDGE_CONFIG_PATH="${_CONFIG}"
    _ROBOT=$(python3 -c "
import json, re, sys
cfg = json.loads(re.sub(r'//[^\n]*', '', open(sys.argv[1]).read()))
print(cfg['robot']['launch'].split('/')[-2])
" "${_CONFIG}" 2>/dev/null) || _ROBOT=openarm
    exec python3 /opt/mujoco_backbone/robots/openarm/mujoco/${_ROBOT}/launch.py "$@"
