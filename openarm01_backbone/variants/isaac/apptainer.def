# TODO: replace with a custom pre-built image once published (avoids 15 GB OCI fetch)
Bootstrap: docker
From: nvcr.io/nvidia/isaac-sim:5.1.0

%labels
    Name openarm01-backbone-isaac
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/peppy_python:/opt/isaac_backbone/exts/omni.peppy.backbone:/opt/nodes_shared_code:/opt/isaac_backbone/.peppy/libs:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-0}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export DISPLAY=${DISPLAY:-:1}

# Shared assets are bind-mounted at runtime via mount_paths in peppy.json5.
%files

%runscript
    cd /isaac-sim
    _PRESET="${PEPPY_BRIDGE_PRESET:-isaac_openarm}"
    _CONFIG="/opt/isaac_backbone/config/presets/${_PRESET}.json5"
    if [ ! -f "${_CONFIG}" ]; then
        echo "ERROR: isaac backbone preset not found: ${_CONFIG}" >&2
        echo "       Set PEPPY_BRIDGE_PRESET to a valid preset name." >&2
        exit 1
    fi
    export PEPPY_BRIDGE_CONFIG_PATH="${_CONFIG}"
    _ROBOT=$(./python.sh -c "
import json, re, sys
cfg = json.loads(re.sub(r'//[^\n]*', '', open(sys.argv[1]).read()))
print(cfg['robot']['launch'].split('/')[-2])
" "${_CONFIG}" 2>/dev/null) || _ROBOT=openarm
    exec ./python.sh /opt/isaac_backbone/robots/openarm/isaac/${_ROBOT}/launch.py "$@"
