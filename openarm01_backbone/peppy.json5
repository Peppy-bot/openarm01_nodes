// Backbone orchestrator — receives move_arm goals from joint_commander, calls IK and
// collision detection, routes commands to openarm01_arm/openarm01_gripper, and
// re-publishes raw peppylib sensor data from the sim as typed peppygen topics.
{
  schema_version: 1,
  manifest: {
    name: "openarm01_backbone",
    tag: "0.1.0",
    depends_on: {
      nodes: [
        {
          name: "inverse_kinematic",
          tag: "0.1.0",
          local_id: "ik"
        },
        {
          name: "collisions_detection",
          tag: "0.1.0",
          local_id: "collisions"
        },
        {
          name: "openarm01_arm",
          tag: "0.1.0",
          local_id: "arm"
        },
        {
          name: "openarm01_gripper",
          tag: "0.1.0",
          local_id: "gripper"
        },
      ]
    },
    variants: [
      {
        name: "default",
        source: {
          local: "./variants/real"
        }
      },
      {
        name: "mujoco",
        source: {
          local: "./variants/mujoco"
        }
      },
      {
        name: "isaac",
        source: {
          local: "./variants/isaac"
        }
      },
    ]
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              feedback_frequency: "u32",
              // x, y, z
              desired_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // quaternion x, y, z, w
              desired_orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              current_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              final_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              action_time: "f64"
            }
          }
        }
      ]
    },
    services: {
      consumes: [
        {
          local_node_id: "arm",
          name: "get_arm_id",
        },
        {
          local_node_id: "gripper",
          name: "get_gripper_id",
        },
      ]
    },
    // Sensor topics translated from peppylib (sim) → peppygen (PeppyOS).
    // Consumed by openarm01_joint_commander.
    topics: {
      emits: [
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            positions: { $type: "array", $items: "f64" },
            velocities: { $type: "array", $items: "f64" },
            stamp: "f64"
          }
        },
        {
          name: "imu",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            orientation: { $type: "array", $items: "f64", $length: 4 },
            angular_velocity: { $type: "array", $items: "f64", $length: 3 },
            linear_acceleration: { $type: "array", $items: "f64", $length: 3 },
            stamp: "f64"
          }
        },
        {
          name: "ee_pose",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            position: { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp: "f64"
          }
        },
        {
          name: "tf_tree",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            frames: {
              $type: "array",
              $items: {
                name: "string",
                parent: "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                orientation: { $type: "array", $items: "f64", $length: 4 }
              }
            },
            stamp: "f64"
          }
        },
        {
          name: "clock",
          qos_profile: "sensor_data",
          message_format: {
            step: "u64",
            sim_time: "f64",
            stamp: "f64"
          }
        },
        {
          name: "odometry",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            position: { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            linear_velocity: { $type: "array", $items: "f64", $length: 3 },
            angular_velocity: { $type: "array", $items: "f64", $length: 3 },
            stamp: "f64"
          }
        },
        {
          name: "wrench",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            force: { $type: "array", $items: "f64", $length: 3 },
            torque: { $type: "array", $items: "f64", $length: 3 },
            stamp: "f64"
          }
        },
        {
          name: "contact_forces",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            contacts: {
              $type: "array",
              $items: {
                body1: "string",
                body2: "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force: { $type: "array", $items: "f64", $length: 3 }
              }
            },
            stamp: "f64"
          }
        },
        {
          name: "gripper_state",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            joint_names: { $type: "array", $items: "string" },
            positions: { $type: "array", $items: "f64" },
            applied_forces: { $type: "array", $items: "f64" },
            stamp: "f64"
          }
        },
      ]
    }
  },
}
