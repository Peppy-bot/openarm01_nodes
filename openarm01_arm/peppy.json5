// This node represents a single arm in the openarm01 robot, the user will instanciate two different arm, each with a different `arm_id` input parameter.
// This is a root component node — openarm01_backbone depends on it, not the other way around.
// It is a "stupid" node that relays safe joint position commands from openarm01_backbone to either the real robot or the sims.
{
  schema_version: 1,
  manifest: {
    name: "openarm01_arm",
    tag: "0.1.0",
    variants: [
      // The real thing
      {
        name: "default",
        source: {
          local: "./variants/default"
        }
      },
      // The isaac sim variant
      {
        name: "isaac",
        source: {
          local: "./variants/isaac"
        }
      },
      // The mujoco variant
      {
        name: "mujoco",
        source: {
          local: "./variants/mujoco"
        }
      },
    ]
  },
  // Non exhaustive list of interfaces
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_arm",
          goal_service: {
            // TODO: Maybe add "feedback_frequency" to the request parameters here
            request_message_format: {
              // The arm ID to understand if it's left of right
              arm_id: "u8",
              // x, y, z
              desired_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // quaternion x, y, z, w
              desired_orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          // Streamed as the arm moves toward the goal
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              current_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              sim_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              final_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              sim_time: "f64"
            }
          }
        }
      ]
    },
  },
}