{
  schema_version: 1,
  manifest: {
    name: "uvc_camera",
    tag: "0.1.0",
    labels: [
      "uvc",
      "camera",
    ],
    variants: [
      {
        name: "default",
        source: {
          local: "./variants/linux"
        }
      },
      {
        name: "macos",
        source: {
          local: "./variants/macos"
        }
      },
      {
        name: "mock-rust",
        source: {
          local: "./variants/mock_rust"
        }
      },
      {
        name: "mock-python",
        source: {
          local: "./variants/mock_python"
        }
      },
      // That node needs to be written an plugs into the mujoco process
      {
        name: "mujoco",
        source: {
          local: "./variants/mujoco"
        }
      },
      // That node needs to be written an plugs into the isaac sim process
      {
        name: "isaac",
        source: {
          local: "./variants/isaac"
        }
      },
    ]
  },
  interfaces: {
    topics: {
      emits: [
        {
          name: "video_stream",
          qos_profile: "sensor_data",
          message_format: {
            header: {
              $type: "object",
              stamp: "time",
              frame_id: "u32",
            },
            encoding: "string",
            width: "u32",
            height: "u32",
            frame: {
              $type: "array",
              $items: "u8",
              $length: 3
            },
          },
        }
      ],
    },
    services: {
      exposes: [
        {
          name: "video_stream_info",
          response_message_format: {
            width: "u32",
            height: "u32",
            frames_per_second: "u8",
            encoding: "string",
          }
        },
        {
          name: "set_exposure",
          request_message_format: {
            mode: "string",
            value: "i32",
          },
          response_message_format: {
            success: "bool",
            message: "string",
            current_value: "i32",
          },
        },
        {
          name: "set_white_balance",
          request_message_format: {
            mode: "string",
            temperature: "i32",
          },
          response_message_format: {
            success: "bool",
            message: "string",
            current_temperature: "i32",
          },
        },
        {
          name: "set_gain",
          request_message_format: {
            value: "i32",
          },
          response_message_format: {
            success: "bool",
            message: "string",
            current_value: "i32",
          },
        },
        {
          name: "set_brightness",
          request_message_format: {
            value: "i32",
          },
          response_message_format: {
            success: "bool",
            message: "string",
            current_value: "i32",
          },
        },
        {
          name: "set_contrast",
          request_message_format: {
            value: "i32",
          },
          response_message_format: {
            success: "bool",
            message: "string",
            current_value: "i32",
          },
        },
      ]
    },
  }
}